generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String         @id @default(uuid())
  email               String         @unique
  password            String
  firstName           String
  lastName            String
  phoneNumber         String
  roleId              String
  failedLoginAttempts Int            @default(0)
  lockUntil           DateTime?
  createdAt           DateTime       @default(now())
  createdBy           String?
  updatedAt           DateTime?
  updatedBy           String?
  deletedAt           DateTime?
  deletedBy           String?
  isDeleted           Boolean        @default(false)

  role                Role           @relation(fields: [roleId], references: [id])
  refreshTokens       RefreshToken[]
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime?
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?
  isDeleted Boolean  @default(false)
  users     User[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime?
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?
  isDeleted Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}